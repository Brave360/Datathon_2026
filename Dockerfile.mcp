FROM node:22-alpine AS widget-build

WORKDIR /web

COPY apps_sdk/web/package.json ./package.json
COPY apps_sdk/web/package-lock.json ./package-lock.json
RUN npm ci

COPY apps_sdk/web ./
RUN npm run build


FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml ./
RUN pip install --no-cache-dir uv && uv pip install --system .

COPY app ./app
COPY apps_sdk ./apps_sdk
COPY raw_data ./raw_data
COPY README.md ./
COPY --from=widget-build /web/dist ./apps_sdk/web/dist

ENV LISTINGS_RAW_DATA_DIR=/app/raw_data
ENV LISTINGS_DB_PATH=/data/listings.db

EXPOSE 8001

CMD ["uvicorn", "apps_sdk.server.main:app", "--host", "0.0.0.0", "--port", "8001"]
